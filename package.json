{
  "name": "foundry-card",
  "version": "26.2.3",
  "description": "A collection of custom dashboard cards for Home Assistant",
  "type": "module",
  "main": "dist/foundry-card.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "esbuild src/foundry-card.js --bundle --format=esm --target=es2020 --outfile=dist/foundry-card.js && robocopy . dist themes.yaml /XO /NJH /NJS /NFL /NDL || if %ERRORLEVEL% LEQ 1 exit 0",
    "watch": "esbuild src/foundry-card.js --bundle --format=esm --target=es2020 --outfile=dist/foundry-card.js --sourcemap --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dprischak/Foundry-Card.git"
  },
  "keywords": [
    "iot",
    "chart",
    "slider",
    "clock",
    "button",
    "entities",
    "themes",
    "thermostat",
    "uptime",
    "home-assistant",
    "industrial",
    "thermometer",
    "gauge",
    "title",
    "vintage",
    "hacs",
    "lovelace",
    "home-assistant-card"
  ],
  "author": "dprischak",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dprischak/Foundry-Card/issues"
  },
  "homepage": "https://github.com/dprischak/Foundry-Card#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.7",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.7"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
